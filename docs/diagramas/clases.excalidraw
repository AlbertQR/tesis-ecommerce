      "id": "order-fields",
      "type": "text",
      "x": 570,
      "y": 115,
      "text": "+ id: ObjectId\n+ userId: ObjectId\n+ items: OrderItem[]\n+ address: Address\n+ subtotal: number\n+ deliveryFee: number\n+ total: number\n+ status: OrderStatus\n+ paymentStatus: PaymentStatus\n+ paymentMethod: string\n+ transactionUuid?: string\n+ hasDelivery: boolean\n+ expiresAt: Date\n+ createdAt: Date\n+ updatedAt: Date",
