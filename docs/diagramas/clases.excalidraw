{
  "type": "excalidraw",
  "version": 2,
  "source": "https://excalidraw.com",
  "elements": [
    {
      "id": "title",
      "type": "text",
      "x": 280,
      "y": 20,
      "text": "Diagrama de Clases - Modelos de Datos",
      "fontSize": 20,
      "fontFamily": "Arial",
      "fontWeight": "bold"
    },
    {
      "id": "user-model",
      "type": "rectangle",
      "x": 40,
      "y": 80,
      "width": 220,
      "height": 200,
      "fill": "#e7f5ff",
      "stroke": "#1971c2",
      "strokeWidth": 2,
      "boundElements": [{"type": "text", "id": "user-title"}]
    },
    {
      "id": "user-title",
      "type": "text",
      "x": 115,
      "y": 85,
      "text": "User",
      "fontSize": 16,
      "fontFamily": "Arial",
      "fontWeight": "bold",
      "containerId": "user-model"
    },
    {
      "id": "user-fields",
      "type": "text",
      "x": 50,
      "y": 115,
      "text": "+ id: ObjectId\n+ email: string\n+ password: string\n+ name: string\n+ phone: string\n+ avatar?: string\n+ role: 'user' | 'admin'\n+ cart: CartItem[]\n+ cartExpiresAt: Date\n+ createdAt: Date\n+ updatedAt: Date",
      "fontSize": 11,
      "fontFamily": "monospace"
    },
    {
      "id": "product-model",
      "type": "rectangle",
      "x": 300,
      "y": 80,
      "width": 220,
      "height": 180,
      "fill": "#e7f5ff",
      "stroke": "#1971c2",
      "strokeWidth": 2,
      "boundElements": [{"type": "text", "id": "product-title"}]
    },
    {
      "id": "product-title",
      "type": "text",
      "x": 365,
      "y": 85,
      "text": "Product",
      "fontSize": 16,
      "fontFamily": "Arial",
      "fontWeight": "bold",
      "containerId": "product-model"
    },
    {
      "id": "product-fields",
      "type": "text",
      "x": 310,
      "y": 115,
      "text": "+ id: ObjectId\n+ name: string\n+ description: string\n+ price: number\n+ category: Category\n+ image: string\n+ isFeatured: boolean\n+ isHot: boolean\n+ isCombo: boolean\n+ stock: number\n+ createdAt: Date\n+ updatedAt: Date",
      "fontSize": 11,
      "fontFamily": "monospace"
    },
